{
  "scripts": {
    "dev": "npm run development",
    "build": "rimraf assets/build && npm run build:js && npm run build:css",
    "build:js": "rollup -c",
    "build:css": "postcss assets/css/*.css --dir assets/build/css --ext .min.css",
    "docs:build": "cd docs; vuepress build",
    "ui:build": "(cd assets/elevator-ui && yarn build)",
    "ui:build:watch": "(cd assets/elevator-ui && yarn build:watch)"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "cssnano": "^7.0.6",
    "postcss": "^8.5.1",
    "postcss-cli": "^11.0.0",
    "rimraf": "^6.0.1",
    "rollup": "^2.79.2",
    "rollup-plugin-sourcemaps": "^0.6.3",
    "rollup-plugin-terser": "^7.0.2"
  },
  "dependencies": {
    "@vuepress/plugin-blog": "^1.9.4",
    "natives": "^1.1.6",
    "vuepress": "^1.8.2"
  }
}
